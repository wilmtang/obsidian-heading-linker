{
  "name": "obsidian-heading-linker",
  "version": "1.0.7",
  "description": "A comprehensive heading utility: Copy markdown links to headings, safely rename headings (refactor), and search for heading references.",
  "main": "main.js",
  "scripts": {
    "build": "esbuild main.ts --bundle --external:obsidian --outfile=main.js --format=cjs --target=node16",
    "dev": "npm run build -- --watch",
    "lint:obsidian": "eslint main.ts",
    "typecheck": "tsc --noEmit",
    "check:release": "npm run typecheck && npm run lint:obsidian && npm run build"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "obsidian": "^1.12.3",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "typescript": "^6.0.3"
  }
}
