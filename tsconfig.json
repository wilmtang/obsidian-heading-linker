{
	"compilerOptions": { "ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ESNext",
		"allowJs": true,
		"noImplicitAny": true,
		"lib": [
			"DOM",
			"ESNext"
		],
		"moduleResolution": "node",
		"importHelpers": true,
		"isolatedModules": true,
		"strict": true
	},
	"include": [
		"**/*.ts"
	]
}
