{
	"compilerOptions": { "ignoreDeprecations": "6.0",
		"baseUrl": ".",
		"inlineSourceMap": true,
		"inlineSources": true,
		"module": "ESNext",
		"target": "ESNext",
		"allowImportingTsExtensions": true,
		"allowJs": true,
		"noImplicitAny": true,
		"lib": [
			"DOM",
			"ESNext"
		],
		"moduleResolution": "bundler",
		"importHelpers": true,
		"isolatedModules": true,
		"strict": true
	},
	"include": [
		"**/*.ts"
	],
	"exclude": [
		"test/e2e/**"
	]
}
